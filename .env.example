# ── CONFIGURATION KAFKALEARN BACKEND ──

# ── Database ──
DATABASE_URL=postgresql://kafkalearn_user:kafkalearn_password@localhost:15432/kafkalearn_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=1800
AUTO_CREATE_DB=false

# ── Redis ──
REDIS_URL=redis://localhost:16379/0
REDIS_SESSION_TTL=3600
REDIS_OTP_TTL=600

# ── Search Infrastructure ──
VESPA_URL=http://localhost:18080
VESPA_CONFIG_URL=http://localhost:19071
MEILI_URL=http://localhost:17700
MEILI_MASTER_KEY=kafkalearn_master_key
MEILI_INDEX=documents
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── LLM Providers ──
LLM_PROVIDER=openrouter
LLM_PROVIDER_SKILL=
LLM_PROVIDER_SEARCH=

OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_FALLBACK=google/gemma-3-12b
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
LLM_MAX_CONCURRENT_REQUESTS=2
LLM_MIN_INTERVAL_MS=250

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Auth & Security ──
JWT_SECRET_KEY=votre_secret_jwt_genere_aleatoirement
REFRESH_SECRET_KEY=votre_refresh_secret_jwt_genere
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Payment (NotchPay) ──
NOTCH_PUBLIC_KEY=sb.test_public_...
NOTCH_SECRET_KEY=sb.test_secret_...
NOTCH_PRIVATE_KEY=sb.test_private_...
NOTCH_WEBHOOK_HASH_KEY=votre_hash_webhook_notchpay
NOTCH_CALLBACK_URL=http://localhost:3000/payment/callback
NOTCH_WEBHOOK_URL=http://votre-url.io/payment/webhook

# ── Email (Brevo) ──
BREVO_API_KEY=votre_cle_brevo_v3
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=contact@app.cm

# ── Firebase (Notifications Push) ──
FIREBASE_SERVICE_ACCOUNT_PATH=/abs/path/to/firebase-service-account.json

# ── Google OAuth ──
GOOGLE_CLIENT_ID=votre_google_client_id

# ── Quotas IA ──
QUOTA_IA_FREE=5
QUOTA_IA_PREMIUM=10
QUOTA_IA_PRO=25
QUOTA_IA_UNLIMITED=200

# ── URLs & CORS ──
BACKEND_URL=http://localhost:9990
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Application ──
APP_VERSION=0.1.0
API_DEBUG=false
DATA_DIR=./data
MAX_UPLOAD_SIZE_MB=20
FASTEMBED_CACHE_DIR=./.cache/fastembed

# ── Misc ──
SEARCH_SCORE_THRESHOLD=0.0
